{
  "name": "trading-dashboard-cf",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create trading-dashboard-db",
    "db:init": "wrangler d1 execute trading-dashboard-db --file=./schema.sql",
    "db:local": "wrangler d1 execute trading-dashboard-db --local --file=./schema.sql",
    "kv:create": "wrangler kv namespace create SESSIONS"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
